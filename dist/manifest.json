{
    "_version": "1.12.0",
    "sap.app": {
        "id": "Ingles.AddOn.CreateEditMaterial",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "1.0.0"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "sourceTemplate": {
            "id": "ui5template.basicSAPUI5ApplicationProject",
            "version": "1.38.11"
        },
        "dataSources": {
            "CostUpdatesSource": {
                "uri": "data/CostUpdates.json",
                "type": "JSON"
            },
            "VendorFundsSource": {
                "uri": "data/VendorFunds.json",
                "type": "JSON"
            }
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "icons": {
            "icon": "",
            "favIcon": "",
            "phone": "",
            "phone@2": "",
            "tablet": "",
            "tablet@2": ""
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": false,
        "rootView": {
            "viewName": "Ingles.AddOn.CreateEditMaterial.view.CreateEditMaterial",
            "type": "XML",
            "async": true,
            "id": "CreateEditMaterial"
        },
        "dependencies": {
            "minUI5Version": "1.60.1",
            "libs": {
                "sap.ui.layout": {},
                "sap.ui.core": {},
                "sap.m": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "Ingles.AddOn.CreateEditMaterial.i18n.i18n"
                }
            },
            "CostUpdatesModel": {
                "type": "sap.ui.model.json.JSONModel",
                "dataSource": "CostUpdatesSource"
            },
            "VendorFundsModel": {
                "type": "sap.ui.model.json.JSONModel",
                "dataSource": "VendorFundsSource"
            }
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "routing": {
            "config": {
                "routerClass": "sap.m.routing.Router",
                "viewType": "XML",
                "async": true,
                "viewPath": "Ingles.AddOn.CreateEditMaterial.view",
                "controlAggregation": "pages",
                "controlId": "app",
                "clearControlAggregation": false
            },
            "routes": [
                {
                    "name": "RouteCreateEditMaterial",
                    "pattern": "RouteCreateEditMaterial",
                    "target": [
                        "TargetCreateEditMaterial"
                    ]
                }
            ],
            "targets": {
                "TargetCreateEditMaterial": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "CreateEditMaterial",
                    "viewName": "CreateEditMaterial"
                }
            }
        }
    },
    "sap.platform.abap": {
        "uri": "/sap/bc/ui5_ui5/aplx/createeditmatl/webapp",
        "_version": "1.1.0"
    }
}