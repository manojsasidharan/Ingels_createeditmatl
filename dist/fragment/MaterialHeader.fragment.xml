<core:FragmentDefinition
	xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core" 
	xmlns:f="sap.ui.layout.form" 
	xmlns:mvc="sap.ui.core.mvc" 
	xmlns="sap.m"
	class="sapUiSizeCompact">
	
	<f:SimpleForm
							editable="true"
							layout="ResponsiveGridLayout"
							adjustLabelSpan="false"
							columnsXL="1"
							columnsL="1"
							columnsM="1"
							singleContainerFullSize="false" >
							<f:content>
								<Label fieldGroupIds="lbl"  text="Ref. Material" wrapping="false">
									<layoutData>
										<l:GridData span="XL1 L1 M2 S3" />
									</layoutData>
								</Label>
								<Input value="{RefMaterial}">
									<layoutData>
										<l:GridData span="XL2 L2 M2 S3" />
									</layoutData>
								</Input>
								<Label fieldGroupIds="lbl"  text="Matl. Number" wrapping="false">
									<layoutData>
										<l:GridData span="XL1 L1 M2 S3" />
									</layoutData>
								</Label>
								<Input value="{MatNo}">
									<layoutData>
										<l:GridData span="XL2 L2 M2 S3" />
									</layoutData>
								</Input>
								<Label fieldGroupIds="lbl"  text="Description" wrapping="false">
									<layoutData>
										<l:GridData span="XL1 L1 M2 S3" />
									</layoutData>
								</Label>
								<Input value="{Description}">
									<layoutData>
										<l:GridData span="XL5 L5 M2 S9" />
									</layoutData>
								</Input>
							</f:content>
						</f:SimpleForm>
</core:FragmentDefinition>