<core:FragmentDefinition
	xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core" 
	xmlns:f="sap.ui.layout.form" 
	xmlns:mvc="sap.ui.core.mvc" 
	xmlns:t="sap.ui.table"
	xmlns="sap.m"
	class="sapUiSizeCompact">

<Dialog title="Vendor Funding - 20355, PICTSWEET FROZEN FOODS" class="sapUiSizeCompact">
	<content>
		
		<t:Table width="800px"
				rows="{VendorFundsModel>/}"
				selectionMode="None"
				visibleRowCount="4"
				ariaLabelledBy="title">
				<t:columns>
					<t:Column width="200px">
						<Label text="Particulars"></Label>
						<t:template>
							<Text text="{VendorFundsModel>Name}" wrapping="false" />
						</t:template>
					</t:Column>
					<t:Column resizable="false" width="150px">
						<Label text="Value"></Label>
						<t:template>
							<Input value="{VendorFundsModel>Value}" type="Number" textAlign="Right"/>
						</t:template>
					</t:Column>
					<t:Column resizable="false" width="150px" >
						<Label text="From"></Label>
						<t:template>
							<DatePicker />
						</t:template>
					</t:Column>
					<t:Column resizable="false" width="150px" >
						<Label text="Till"></Label>
						<t:template>
							<DatePicker />
						</t:template>
					</t:Column>
					<t:Column resizable="false" width="120px">
						<Label text="Item Level?"></Label>
						<t:template>
							<CheckBox text="Item Level"></CheckBox>
						</t:template>
					</t:Column>
				</t:columns>
			</t:Table>
	</content>
	<buttons>
		<Button type="Emphasized" width="100px" icon="sap-icon://accept" text="OK" press="onVendorFundingCancel"></Button>
		<Button width="100px" icon="sap-icon://cancel" text="Cancel" press="onVendorFundingCancel"></Button>
	</buttons>
</Dialog>

</core:FragmentDefinition>