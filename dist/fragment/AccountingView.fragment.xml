<core:FragmentDefinition
	xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core" 
	xmlns:f="sap.ui.layout.form" 
	xmlns:mvc="sap.ui.core.mvc" 
	xmlns="sap.m"
	class="sapUiSizeCompact">

<Dialog title="Accounting View" class="sapUiSizeCompact">
	<content>
		<OverflowToolbar>
			<Label text="General Valuation Data"/>
			<ToolbarSpacer/>
		</OverflowToolbar>
		<l:Grid defaultSpan="XL6 L6 M6 S12"><l:content>
			<List width="350px" class="PAList">
				<InputListItem label="Total Stock"><Input width="150px" /></InputListItem>
			</List>
			<List width="350px" class="PAList">
				<InputListItem label="Valuation Class"><Input width="150px" /></InputListItem>
			</List>
		</l:content></l:Grid>
		<OverflowToolbar >
			<Label text="Prices and Values"/>
			<ToolbarSpacer/>
		</OverflowToolbar>
		<l:Grid defaultSpan="XL6 L6 M6 S12"><l:content>
			<List width="350px" class="PAList">
				<InputListItem label="Standard Price"><Input width="150px" /></InputListItem>
				<InputListItem label="Price Per Unit"><Input width="150px" /></InputListItem>
				<InputListItem label="Price Control"><Input width="150px" /></InputListItem>
				<InputListItem label="Future Price"><Input width="150px" /></InputListItem>
				<InputListItem label="Future Price From"><DatePicker width="150px"/></InputListItem>
				<InputListItem label="Previous Price"><Input width="150px" /></InputListItem>
			</List>
			<List width="350px" class="PAList">
				<InputListItem label="Currency"><Input width="150px" /></InputListItem>
				<InputListItem label="Price Unit"><Input width="150px" /></InputListItem>
				<InputListItem label="Inventory Value"><Input width="150px" /></InputListItem>
				<InputListItem label="Average Weight"><Input width="150px" /></InputListItem>
				<InputListItem label="Last Price Change"><Input width="150px"/></InputListItem>
			</List>
		</l:content></l:Grid>
	</content>
	<buttons>
		<Button type="Emphasized" width="100px" icon="sap-icon://accept" text="OK" press="onAccountingViewCancel"></Button>
		<Button width="100px" icon="sap-icon://cancel" text="Cancel" press="onAccountingViewCancel"></Button>
	</buttons>
</Dialog>

</core:FragmentDefinition>